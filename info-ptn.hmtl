<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Info PTN - Akadara</title>
    <style>
        /* Mengatur dasar halaman agar pas dengan tema gelap Akadara */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            width: 100%;
            height: 100vh;
            background-color: #121212; /* Hitam pekat sesuai bg utama */
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
            font-family: 'Poppins', sans-serif;
        }

        /* Wadah aplikasi agar responsif dan estetik */
        .app-container {
            width: 95%;
            height: 90vh;
            background: rgba(26, 26, 26, 0.75);
            border-radius: 12px;
            border: 1px solid rgba(211, 3, 3, 0.4); /* Border merah khas Akadara */
            box-shadow: 0 8px 32px rgba(211, 3, 3, 0.2); /* Glow merah soft */
            overflow: hidden;
        }

        /* Pengaturan frame aplikasi Python Hugging Face */
        iframe {
            width: 100%;
            height: 100%;
            border: none;
        }
    </style>
</head>
<body>

    <div class="app-container">
        <iframe src="https://drawrwr-akadara.hf.space"></iframe>
    </div>

</body>
</html>
